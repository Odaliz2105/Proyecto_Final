<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sazón EPN - Iniciar Sesión</title>
    <link rel="stylesheet" href="/css/estilo.css">
</head>

<body>

    <header class="barra-superior">
        <div>
            <h1>Sazón EPN</h1>
            <p class="subtitulo-sistema">
                Inventario Gastronómico Distribuido
            </p>
        </div>

        <span class="etiqueta-nodo">
            Atendido por: <%= nombreNodo %>
        </span>
    </header>

    <div class="contenedor-login">

        <div class="caja-login">

            <h2>Iniciar Sesión</h2>

            <p class="texto-ayuda" style="text-align: center;">
                Accede al sistema de gestión de productos gastronómicos.
            </p>

            <% if (error) { %>
                <div class="alerta-error">
                    <%= error %>
                </div>
            <% } %>

            <form
                action="/login"
                method="POST"
                accept-charset="UTF-8"
            >

                <div class="campo-formulario">
                    <label>Usuario:</label>

                    <input
                        type="text"
                        name="usuario"
                        placeholder="Ej: admin o cliente"
                        autocomplete="username"
                        required
                    >
                </div>

                <div class="campo-formulario">
                    <label>Contraseña:</label>

                    <div class="contenedor-password">
                        <input
                            type="password"
                            name="clave"
                            id="input-clave"
                            placeholder="••••••••"
                            autocomplete="current-password"
                            required
                        >
                        <button type="button" id="btn-toggle-clave" class="btn-toggle-password" aria-label="Mostrar contraseña" title="Mostrar contraseña">
                            <svg class="icono-ojo" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </button>
                    </div>
                </div>

                <button
                    type="submit"
                    class="btn-principal"
                >
                    Ingresar al sistema
                </button>

            </form>

        </div>

    </div>

    <script src="/js/login.js"></script>
</body>

</html>