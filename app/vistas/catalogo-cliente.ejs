<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Catálogo de Productos | Sazón EPN</title>
    <link rel="stylesheet" href="/css/estilo.css">
</head>

<body>

    <header class="barra-superior">
        <div>
            <h1>Sazón EPN</h1>
            <p class="subtitulo-sistema">
                Inventario Gastronómico Distribuido
            </p>
        </div>

        <div>
            <span>
                Bienvenido/a,
                <strong>
                    <%= usuarioSesion ? usuarioSesion.nombre : 'Cliente' %>
                </strong>
            </span>

            <span class="etiqueta-nodo" style="margin-left: 10px;">
                Nodo: <%= nombreNodo %>
            </span>

            <a href="/perfil" class="btn-volver">
                Mi Perfil
            </a>

            <a href="/salir" class="btn-salir">
                Cerrar Sesión
            </a>
        </div>
    </header>

    <section class="franja-hero">
        <h2>Productos gastronómicos disponibles</h2>

        <p>
            Consulta nuestro inventario, revisa precios y verifica
            la disponibilidad de cada producto.
        </p>
    </section>

    <main class="contenedor-principal">

        <section class="tarjeta-blanca" style="margin-bottom: 1.5rem;">

            <form
                method="GET"
                action="/cliente"
                style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;"
            >
                <label style="font-weight: 600;">
                    Filtrar por categoría:
                </label>

                <select
                    name="categoria"
                    style="padding: 0.5rem; border-radius: 4px; border: 1px solid #cbd5e1;"
                >
                    <option value="">
                        Todas las categorías
                    </option>

                    <option
                        value="Platos fuertes"
                        <% if (categoriaFiltro === 'Platos fuertes') { %>
                            selected
                        <% } %>
                    >
                        Platos fuertes
                    </option>

                    <option
                        value="Sopas"
                        <% if (categoriaFiltro === 'Sopas') { %>
                            selected
                        <% } %>
                    >
                        Sopas
                    </option>

                    <option
                        value="Entradas"
                        <% if (categoriaFiltro === 'Entradas') { %>
                            selected
                        <% } %>
                    >
                        Entradas
                    </option>

                    <option
                        value="Postres"
                        <% if (categoriaFiltro === 'Postres') { %>
                            selected
                        <% } %>
                    >
                        Postres
                    </option>

                    <option
                        value="Bebidas"
                        <% if (categoriaFiltro === 'Bebidas') { %>
                            selected
                        <% } %>
                    >
                        Bebidas
                    </option>
                </select>

                <button
                    type="submit"
                    class="btn-principal"
                    style="width: auto; padding: 0.5rem 1.5rem;"
                >
                    Filtrar
                </button>
            </form>

        </section>

        <section class="grid-recetas">

            <% productos.forEach(producto => { %>

                <article
                    class="tarjeta-receta tarjeta-clickeable"
                    onclick="abrirDetalleCliente('<%= producto.id %>')"
                >

                    <div class="contenedor-imagen-producto">

                        <img
                            src="<%= producto.imagen_url || 'https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=600&q=80' %>"
                            alt="<%= producto.nombre %>"
                            class="imagen-receta"
                        >

                        <span class="etiqueta-disponible">
                            Disponible
                        </span>

                    </div>

                    <div class="cuerpo-tarjeta">

                        <span class="categoria-badge">
                            <%= producto.categoria %>
                        </span>

                        <h3>
                            <%= producto.nombre %>
                        </h3>

                        <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 0.5rem;">
                            <%= producto.descripcion || 'Sin descripción disponible.' %>
                        </p>

                        <p style="font-size: 0.85rem;">
                            <strong>Stock:</strong>
                            <%= producto.stock %>
                            <%= producto.unidad %>
                        </p>

                        <p class="precio-producto">
                            $<%= Number(producto.precio).toFixed(2) %>
                        </p>

                        <button
                            type="button"
                            class="btn-agregar"
                            onclick="event.stopPropagation(); agregarAlPedido('<%= producto.nombre %>')"
                        >
                            Agregar al pedido
                        </button>

                    </div>

                </article>

            <% }) %>

        </section>

        <% if (productos.length === 0) { %>

            <section
                class="tarjeta-blanca"
                style="text-align: center; margin-top: 1.5rem;"
            >
                <p>
                    No hay productos disponibles para esta categoría.
                </p>
            </section>

        <% } %>

    </main>

    <div id="modal-fondo" class="modal-fondo">

        <div class="modal-caja">

            <button
                type="button"
                class="modal-cerrar"
                onclick="cerrarModalCliente()"
            >
                &times;
            </button>

            <img
                id="detalle-imagen"
                src=""
                alt=""
                class="modal-imagen"
            >

            <span
                id="detalle-categoria"
                class="categoria-badge"
            ></span>

            <h2 id="detalle-nombre"></h2>

            <p>
                <strong>Stock disponible:</strong>
                <span id="detalle-stock"></span>
            </p>

            <p>
                <strong>Unidad:</strong>
                <span id="detalle-unidad"></span>
            </p>

            <p>
                <strong>Precio:</strong>
                $<span id="detalle-precio"></span>
            </p>

            <h4>Descripción</h4>

            <p id="detalle-descripcion"></p>

            <div class="acciones-modal">

                <button
                    type="button"
                    class="btn-principal"
                    style="width: auto;"
                    id="detalle-agregar"
                >
                    Agregar al pedido
                </button>

            </div>

        </div>

    </div>

    <script src="/js/cliente.js"></script>

</body>

</html>