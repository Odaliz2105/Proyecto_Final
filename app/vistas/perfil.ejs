<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Mi Perfil | Sazón EPN</title>
    <link rel="stylesheet" href="/css/estilo.css">
</head>

<body>

    <header class="barra-superior">

        <div>
            <h1>Sazón EPN</h1>

            <p class="subtitulo-sistema">
                Mi Perfil
            </p>
        </div>

        <div>
            <span>
                Bienvenido/a,
                <strong>
                    <%= usuarioSesion ? usuarioSesion.nombre : 'Usuario' %>
                </strong>
            </span>

            <span
                class="etiqueta-nodo"
                style="margin-left: 10px;"
            >
                Nodo: <%= nombreNodo %>
            </span>

            <a
                href="<%= datos.rol === 'admin' ? '/admin' : '/cliente' %>"
                class="btn-volver"
            >
                Volver al panel
            </a>

            <a
                href="/salir"
                class="btn-salir"
            >
                Cerrar sesión
            </a>
        </div>

    </header>

    <main class="contenedor-principal contenedor-angosto">

        <section class="tarjeta-blanca tarjeta-perfil">

            <div class="cabecera-perfil">

                <div class="avatar-circulo">
                    <%= (datos.nombre_completo || datos.nombre || 'U').charAt(0).toUpperCase() %>
                </div>

                <div>

                    <h2>
                        <%= datos.nombre_completo || datos.nombre %>
                    </h2>

                    <span class="rol-badge">
                        <%= datos.rol === 'admin' ? 'Administrador' : 'Cliente' %>
                    </span>

                    <% if (datos.usuario) { %>

                        <p class="texto-ayuda" style="margin-top: 0.35rem; margin-bottom: 0;">
                            Usuario:
                            <strong><%= datos.usuario %></strong>
                        </p>

                    <% } %>

                </div>

            </div>

            <% if (error) { %>

                <div class="alerta-error">
                    <%= error %>
                </div>

            <% } %>

            <% if (exito) { %>

                <div class="alerta-exito">
                    <%= exito %>
                </div>

            <% } %>

            <form
                action="/perfil"
                method="POST"
                accept-charset="UTF-8"
            >

                <h3>Datos personales</h3>

                <hr class="separador">

                <div class="campo-formulario">

                    <label>Nombre completo:</label>

                    <input
                        type="text"
                        name="nombre_completo"
                        value="<%= datos.nombre_completo || datos.nombre || '' %>"
                        required
                    >

                </div>

                <div class="fila-doble">

                    <div class="campo-formulario">

                        <label>Correo electrónico:</label>

                        <input
                            type="email"
                            name="correo"
                            value="<%= datos.correo || '' %>"
                        >

                    </div>

                    <div class="campo-formulario">

                        <label>Teléfono:</label>

                        <input
                            type="text"
                            name="telefono"
                            value="<%= datos.telefono || '' %>"
                        >

                    </div>

                </div>

                <h3 style="margin-top: 1.5rem;">
                    Cambiar contraseña
                </h3>

                <hr class="separador">

                <p class="texto-ayuda">
                    Deja estos campos en blanco si no deseas cambiar tu contraseña.
                </p>

                <div class="campo-formulario">

                    <label>Contraseña actual:</label>

                    <input
                        type="password"
                        name="clave_actual"
                    >

                </div>

                <div class="fila-doble">

                    <div class="campo-formulario">

                        <label>Nueva contraseña:</label>

                        <input
                            type="password"
                            name="clave_nueva"
                        >

                    </div>

                    <div class="campo-formulario">

                        <label>Confirmar contraseña:</label>

                        <input
                            type="password"
                            name="clave_confirmar"
                        >

                    </div>

                </div>

                <div class="acciones-modal">

                    <button
                        type="submit"
                        class="btn-principal"
                    >
                        Guardar cambios
                    </button>

                </div>

            </form>

        </section>

    </main>

</body>

</html>